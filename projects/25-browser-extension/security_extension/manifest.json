{
  "manifest_version": 3,
  "name": "Security Browser Extension",
  "version": "1.0",
  "description": "Basic security indicators for browsing",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"]
  }]
}
