{
  "name": "openclaw-labs",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw Production Scaffold — TypeScript-first agent coordination monorepo",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "doctor": "pnpm --filter @secdev/shared-cli exec secdev doctor",
    "list": "pnpm --filter @secdev/shared-cli exec secdev list",
    "inventory": "pnpm --filter @secdev/shared-cli exec secdev inventory",
    "validate": "pnpm --filter @secdev/shared-cli exec secdev validate",
    "orchestrator": "pnpm --filter @openclaw/orchestrator start",
    "daemon": "pnpm --filter @openclaw/daemon start",
    "openclaw": "pnpm --filter @openclaw/cli openclaw"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  },
  "packageManager": "pnpm@8.15.1"
}
