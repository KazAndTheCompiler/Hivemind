{
  "name": "kaz-finally-compiles-some-wisdom",
  "version": "1.0.0",
  "description": "Emission-driven multi-agent coordination - The TypeScript Discovery",
  "type": "module",
  "main": "run.mjs",
  "scripts": {
    "run": "node run.mjs",
    "test": "node test_run.ts",
    "harness": "node harness/dist/run-scenarios.js",
    "harness:mock": "node harness/dist/run-mocked.js",
    "harness:baseline": "node harness/dist/run-baseline.js",
    "harness:summary": "node harness/dist/print-summary.js",
    "run:baseline": "node harness/dist/run-baseline.js",
    "run:emission": "node harness/dist/run-scenarios.js",
    "run:mocked": "node harness/dist/run-mocked.js",
    "run:real": "OPENROUTER_API_KEY=$OPENROUTER_API_KEY node harness/dist/run-scenarios.js",
    "print:summary": "node harness/dist/print-summary.js",
    "all": "npm run harness:mock && npm run print:summary",
    "build": "tsc",
    "build:harness": "tsc -p harness/tsconfig.json"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}