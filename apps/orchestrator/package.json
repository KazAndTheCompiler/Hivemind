{
  "name": "@openclaw/orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Orchestrator service — supervisor pattern for worker agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "openclaw-orchestrator": "dist/index.js"
  },
  "scripts": {
    "build": "tsc --build",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openclaw/core-types": "workspace:*",
    "@openclaw/core-config": "workspace:*",
    "@openclaw/core-events": "workspace:*",
    "@openclaw/core-logging": "workspace:*",
    "@openclaw/core-errors": "workspace:*",
    "@openclaw/agent-protocol": "workspace:*",
    "@openclaw/agent-relay": "workspace:*",
    "@openclaw/agent-router": "workspace:*",
    "@openclaw/agent-memory": "workspace:*",
    "@openclaw/summarizer": "workspace:*",
    "@openclaw/watson": "workspace:*",
    "@openclaw/change-detector": "workspace:*",
    "@openclaw/audit-store": "workspace:*",
    "@openclaw/tool-secdev": "workspace:*",
    "@openclaw/tool-eslint": "workspace:*",
    "@openclaw/tool-prettier": "workspace:*",
    "@openclaw/automation-checkpoints": "workspace:*",
    "@openclaw/automation-summary": "workspace:*",
    "@openclaw/guard-stack": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  }
}
