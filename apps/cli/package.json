{
  "name": "@openclaw/cli",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw CLI entry point",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "openclaw": "dist/index.js"
  },
  "scripts": {
    "build": "tsc --build",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openclaw/core-types": "workspace:*",
    "@openclaw/core-config": "workspace:*",
    "@openclaw/core-logging": "workspace:*",
    "@openclaw/core-errors": "workspace:*",
    "@openclaw/orchestrator": "workspace:*",
    "@openclaw/daemon": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  }
}
